{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["mocha", "chai"]
  },
  "include": ["test/**/*.ts", "scripts/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules", "artifacts", "cache"]
}
